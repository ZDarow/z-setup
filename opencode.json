{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2
  },
  "permission": "allow",
  "mcp": {
    "everything": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-everything"]
    }
  },
  "skills": {
    "paths": ["/home/mi/.config/opencode/skills"]
  },
  "instructions": [
    ".opencode/AGENTS.md",
    "README.md"
  ],
  "agent": {
    "coder": {
      "mode": "subagent",
      "steps": 50,
      "temperature": 0.2,
      "description": "Coding specialist"
    },
    "task": {
      "mode": "subagent",
      "steps": 30,
      "temperature": 0.4
    }
  }
}
